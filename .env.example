PORT=4300

# Verbose API request logging and per-message Telegram import logs
# DEBUG=true

# Database: set DATABASE_URL for VPS PostgreSQL, or omit it to use local SQLite.
# DATABASE_URL=postgresql://appbeg_ledger_user:YOUR_PASSWORD@YOUR_VPS_HOST:5432/appbeg_ledger_db
# DATABASE_SSL=true
DATABASE_PATH=./data/royal-vip-coadmin.sqlite
TELEGRAM_BOT_TOKEN=123456789:replace_with_your_bot_token

# Business Telegram account sync (Telethon user account — all private chats)
TELEGRAM_ACCOUNT_SYNC_ENABLED=false
TELEGRAM_ACCOUNT_API_ID=123456
TELEGRAM_ACCOUNT_API_HASH=replace_with_api_hash
TELEGRAM_ACCOUNT_SESSION=./data/telegram-business.session
TELEGRAM_ACCOUNT_IMPORT_LIMIT_PER_DIALOG=0
# Falls back to PAYMENT_TELEGRAM_API_ID / PAYMENT_TELEGRAM_API_HASH if account vars are empty
SYNC_NOTIFY_TOKEN=change_this_local_sync_token

# Registration flow
REGISTRATION_FLOW_COMPLETION_STATUS=Pending Verification
WELCOME_COOLDOWN_HOURS=24
REGISTRATION_TIMEOUT_HOURS=72

# Coadmin identity is configured in Dashboard → Settings (stored in the database, not env)

# Payment Telegram group sync (Telethon, not Bot API)
PAYMENT_TELEGRAM_SYNC_ENABLED=false
PAYMENT_TELEGRAM_API_ID=
PAYMENT_TELEGRAM_API_HASH=
PAYMENT_TELEGRAM_SESSION=./data/telegram-payment.session
PAYMENT_TELEGRAM_GROUP=
PAYMENT_TELEGRAM_IMPORT_LIMIT=500

# AppBeg-first payment routing
DEPOSIT_WINDOW_MINUTES=30
TELELEDGER_API_URL=http://localhost:8000
TELELEDGER_INTERNAL_TOKEN=change_this_local_appbeg_router_token

# Listener roles
CHAT_TELEGRAM_ACCOUNT=business_telegram_account
CHAT_ACCOUNT_LISTENER=business_telegram_account
PAYMENT_GROUP_LISTENER=payment_telegram_group
PAYMENT_GROUP_CHAT_ID=
