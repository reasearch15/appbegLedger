    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:init": "node scripts/db-init.js",
    "db:verify": "node scripts/verify-db.js",
    "cleanup:business-contacts:preview": "node scripts/cleanup-business-account-contacts.js --preview",
    "cleanup:business-contacts:execute": "node scripts/cleanup-business-account-contacts.js --execute",
    "telegram:login": "python scripts/telegram_account_sync.py login",
    "telegram:sync": "python scripts/telegram_account_sync.py sync",
